#!/usr/bin/env bash
# AIDash pre-push hook.
#
# Lives in scripts/hooks/ under version control. Activated in any
# worktree (or main checkout) by running once:
#
#     git config core.hooksPath scripts/hooks
#
# Runs Core tests + workspace build before push. Skips the heavy
# xcodebuild gate for docs-only pushes. Bypass for emergencies with
# `git push --no-verify`.

set -e
set -o pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "$REPO_ROOT"

remote="$1"
url="$2"

# Read the ref ranges being pushed from stdin.
# Format per line: <local_ref> <local_sha> <remote_ref> <remote_sha>
pushing_anything=0
docs_only=1
zero="0000000000000000000000000000000000000000"

while IFS=' ' read -r local_ref local_sha remote_ref remote_sha; do
    [ -z "$local_sha" ] && continue
    [ "$local_sha" = "$zero" ] && continue   # delete; skip

    pushing_anything=1

    if [ "$remote_sha" = "$zero" ]; then
        # New branch on remote — compare against merge-base with main.
        base="$(git merge-base "$local_sha" origin/main 2>/dev/null || echo "")"
    else
        base="$remote_sha"
    fi

    if [ -z "$base" ]; then
        # Can't compute diff range; be conservative.
        docs_only=0
        continue
    fi

    changed_files="$(git diff --name-only "$base..$local_sha")"
    if [ -z "$changed_files" ]; then
        continue
    fi

    # Anything outside docs/, *.md, .specify/, .github/, scripts/hooks/
    # counts as code.
    while IFS= read -r f; do
        case "$f" in
            docs/*|*.md|.specify/*|.github/*|scripts/hooks/*) ;;
            *) docs_only=0 ;;
        esac
    done <<<"$changed_files"
done

if [ "$pushing_anything" = "0" ]; then
    exit 0
fi

# 防腐校验 — 每层 tech-context.md 的 frontmatter 必须与代码一致。
# 即便 docs-only 也跑:tech-context.md 本身就是 docs,改坏了要拦。
if [ -x "scripts/hooks/check-frontmatter" ]; then
    echo "[pre-push] check-frontmatter..."
    if ! scripts/hooks/check-frontmatter; then
        echo "[pre-push] FAILED: frontmatter 与代码不一致"
        exit 1
    fi
fi

if [ "$docs_only" = "1" ]; then
    echo "[pre-push] docs-only push; skipping build/test gate."
    exit 0
fi

# 门:改代码必带测试 —— 改了源码却没动任何测试文件 → 拦。
# 逃生舱:任一 commit message 含 "Allow-No-Tests:" 则放行。
# 范围以本次推送的整体 diff(最后一段 base..local_sha)为准。
if [ -n "${base:-}" ] && [ -n "${local_sha:-}" ]; then
    range_changed="$(git diff --name-only "$base..$local_sha" 2>/dev/null || true)"
    src_changed="$(echo "$range_changed" | grep -E '\.swift$' | grep -vE '(^|/)Tests/|Tests?\.swift$' || true)"
    test_changed="$(echo "$range_changed" | grep -E '(^|/)Tests/|Tests?\.swift$' || true)"
    if [ -n "$src_changed" ] && [ -z "$test_changed" ]; then
        if ! git log "$base..$local_sha" --format=%B 2>/dev/null | grep -qi '^Allow-No-Tests:'; then
            echo "[pre-push] ❌ 改了源码(.swift)但无测试改动。"
            echo "[pre-push]    补对应层的测试,或在某个 commit message 写:Allow-No-Tests: <原因>"
            echo "[pre-push]    改动的源文件:"
            echo "$src_changed" | sed 's/^/[pre-push]      /'
            exit 1
        fi
        echo "[pre-push] ⚠️ 改了源码但无测试改动;因 Allow-No-Tests: 放行。"
    fi
fi

# Test gate — Core package only (fast, no Xcode required for SPM tests).
if [ -d "Packages/AIDashCore" ]; then
    echo "[pre-push] swift test (AIDashCore)..."
    if ! swift test --package-path Packages/AIDashCore > /tmp/aidash-pre-push-test.log 2>&1; then
        echo "[pre-push] FAILED: swift test"
        tail -40 /tmp/aidash-pre-push-test.log
        exit 1
    fi
fi

# Build gate — generate xcodeproj if missing, then build macOS app.
# Skip if xcodegen / xcodebuild not yet available (during very early
# scaffolding tasks T001-T008 the project may not yet exist).
if [ -f "project.yml" ]; then
    if ! command -v xcodegen >/dev/null 2>&1; then
        echo "[pre-push] WARNING: project.yml exists but xcodegen not installed; skipping build gate."
    elif ! command -v xcodebuild >/dev/null 2>&1; then
        echo "[pre-push] WARNING: xcodebuild not found; skipping build gate."
    else
        echo "[pre-push] xcodegen generate..."
        if ! xcodegen generate > /tmp/aidash-pre-push-xcodegen.log 2>&1; then
            echo "[pre-push] FAILED: xcodegen generate"
            tail -40 /tmp/aidash-pre-push-xcodegen.log
            exit 1
        fi

        # If a workspace/project exists, do a macOS build of every shipped
        # target. Both AIDashApp and the aidash CLI must build cleanly —
        # CLI breakage previously slipped through because only AIDashApp
        # was gated here (MY-1023).
        if [ -d "AIDash.xcodeproj" ] || [ -d "AIDash.xcworkspace" ]; then
            echo "[pre-push] xcodebuild AIDashApp (macOS)..."
            if ! xcodebuild -scheme AIDashApp -destination "platform=macOS" \
                    CODE_SIGNING_ALLOWED=NO build \
                    > /tmp/aidash-pre-push-build-app.log 2>&1; then
                echo "[pre-push] FAILED: xcodebuild AIDashApp"
                tail -50 /tmp/aidash-pre-push-build-app.log
                exit 1
            fi

            echo "[pre-push] xcodebuild aidash CLI (macOS)..."
            if ! xcodebuild -scheme aidash -destination "platform=macOS" \
                    CODE_SIGNING_ALLOWED=NO build \
                    > /tmp/aidash-pre-push-build-cli.log 2>&1; then
                echo "[pre-push] FAILED: xcodebuild aidash"
                tail -50 /tmp/aidash-pre-push-build-cli.log
                exit 1
            fi
        fi
    fi
fi

echo "[pre-push] all checks passed."
exit 0
